{
  "name": "@josephakern/pi-tree-sitter-cli",
  "version": "0.2.9",
  "type": "module",
  "description": "Thin pi extension exposing the tree-sitter CLI as capped agent tools.",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "index.ts",
    "src",
    "skills",
    "queries",
    "README.md",
    "PLAN.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "eval:skills": "node scripts/skill-eval.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
